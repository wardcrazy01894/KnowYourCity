node_modules/
dist/
.env
.env.local
.DS_Store
*.log

# Transient git worktrees created for isolated subagent/reviewer runs.
.claude/worktrees/

# Data pipeline output — regenerated by `npm run fetch-pois`; the curated
# public/locations.json is the committed artifact, not this.
data/candidates.json
data/food-candidates.json

# Transient working dirs for a city's crash-safe fame pass (tuples, generated
# workflow script, harvested accumulator). The committed artifact is the final
# data/fame-<city>.json the apply-difficulty step writes, not this scratch.
data/_*-fame-work/

# Scratch dir created by scripts during local runs (e.g. node compile cache).
scripts/tmp/

# Transient Google Places freshness-sweep results (scripts/places-freshness.mjs).
# Holds Google-derived fields used only during a run; per Places ToS we don't
# persist them — the committed artifacts are the lastVerified stamps + status
# changes the apply step writes, not this.
data/.places-*.jsonl
data/.places-*-report.md
data/.hardtail.json

# Transient local-chain disambiguation scratch (scripts/detect-chains.mjs):
# cached Overpass pulls, candidate lists, Google-derived neighborhood labels,
# and the review report. The committed artifact is the renamed names in
# public/locations.<city>.json, not this scratch.
data/.osm-food.*.json
data/.chain-candidates.*.json
data/.chain-label-cache.json
data/.chain-rename-report.md
data/.chain-brands-report.md
data/.nominatim-cache.json
data/.chain-verify-cache.json
data/.chain-reviews-cache.json
data/.chain-open-cache.json

# Local Wrangler state — local D1 SQLite, KV, caches for `wrangler dev`.
.wrangler/
