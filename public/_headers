# Prevent stale caches for assets whose content changes between deploys but
# whose filenames are stable (no content hash in the URL).

/index.html
  Cache-Control: no-cache, must-revalidate

/version.json
  Cache-Control: no-cache, must-revalidate

/locations.stpete.json
  Cache-Control: no-cache, must-revalidate

/locations.annarbor.json
  Cache-Control: no-cache, must-revalidate

/locations.chicago.json
  Cache-Control: no-cache, must-revalidate

/locations.seattle.json
  Cache-Control: no-cache, must-revalidate

/locations.statecollege.json
  Cache-Control: no-cache, must-revalidate
