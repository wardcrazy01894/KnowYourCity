{
  // Type-check the Cloudflare Worker source. The worker is JSDoc-typed plain
  // ESM (.mjs), so it needs allowJs + checkJs — the base tsconfig only compiles
  // the app's .ts/.tsx. Test files (*.test.mjs) are excluded: their vitest mock
  // factories infer over-narrow types that aren't worth annotating around.
  //
  // strict is OFF here on purpose: the worker is loosely JSDoc-typed and its
  // runtime handler signatures (request/env/ctx) would need @cloudflare/workers-
  // types to satisfy noImplicitAny. This pass is a safety net for structural
  // breakage it CAN catch without strict — non-existent property access (TS2339),
  // wrong arg counts (TS2554), unused locals — but NOT wrong arg *types* (that
  // needs strict + workers-types). It's a net, not a full strict-typing retrofit;
  // tighten later if the worker grows.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "worker/leaderboard-lib.mjs",
    "worker/bug-report.mjs",
    "worker/leaderboard.mjs"
  ]
}
