{
  "name": "knowyourlocals",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A daily 'where is it?' map guessing game for local places, starting with St. Petersburg, FL.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "fetch-pois": "node scripts/fetch-pois.mjs",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^6.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
